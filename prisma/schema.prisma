generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VerifiedOrganizerStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ElectionSyncState {
  PREPARED
  INDEXED
  EXPIRED
  FAILED
}

enum OnchainElectionState {
  SCHEDULED
  ACTIVE
  CLOSED
  KEY_REVEAL_PENDING
  KEY_REVEALED
  FINALIZED
  CANCELLED
}

enum VisibilityMode {
  OPEN
  PRIVATE
}

enum PaymentMode {
  FREE
  PAID
}

enum BallotPolicy {
  ONE_PER_ELECTION
  ONE_PER_INTERVAL
  UNLIMITED_PAID
}

model AdminUser {
  id                 BigInt              @id @default(autoincrement())
  email              String              @unique
  passwordHash       String              @map("password_hash")
  role               String
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  verifiedOrganizers VerifiedOrganizer[]

  @@map("admin_users")
}

model VerifiedOrganizer {
  id              BigInt                  @id @default(autoincrement())
  walletAddress   String                  @unique @map("wallet_address")
  status          VerifiedOrganizerStatus
  organizationName String                 @map("organization_name")
  contactEmail    String?                 @map("contact_email")
  organizationLogoUrl String?             @map("organization_logo_url")
  rejectionReason String?                 @map("rejection_reason")
  verifiedBy      BigInt?                 @map("verified_by")
  verifiedAt      DateTime?               @map("verified_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  adminUser       AdminUser?              @relation(fields: [verifiedBy], references: [id])

  @@map("verified_organizers")
}

model ElectionSeries {
  id              BigInt     @id @default(autoincrement())
  seriesPreimage  String     @unique @map("series_preimage")
  onchainSeriesId String?    @unique @map("onchain_series_id")
  coverImageUrl   String?    @map("cover_image_url")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  electionDrafts  ElectionDraft[]

  @@map("election_series")
}

model ElectionDraft {
  id                         BigInt               @id @default(autoincrement())
  seriesId                   BigInt               @map("series_id")
  title                      String
  coverImageUrl              String?              @map("cover_image_url")
  candidateManifestPreimage  Json                 @map("candidate_manifest_preimage")
  visibilityMode             VisibilityMode       @default(PRIVATE) @map("visibility_mode")
  syncState                  ElectionSyncState    @map("sync_state")
  createdAt                  DateTime             @default(now()) @map("created_at")
  updatedAt                  DateTime             @updatedAt @map("updated_at")
  series                     ElectionSeries       @relation(fields: [seriesId], references: [id])
  electionKey                ElectionKey?
  electionCandidates         ElectionCandidate[]
  onchainElection            OnchainElection?

  @@index([seriesId])
  @@map("election_drafts")
}

model OnchainElection {
  id                         BigInt                @id @default(autoincrement())
  draftId                    BigInt?               @unique @map("draft_id")
  onchainSeriesId            String?               @map("onchain_series_id")
  onchainElectionId          String                @unique @map("onchain_election_id")
  onchainElectionAddress     String                @unique @map("onchain_election_address")
  candidateManifestHash      String?               @map("candidate_manifest_hash")
  candidateManifestUri       String?               @map("candidate_manifest_uri")
  organizerWalletAddress     String                @map("organizer_wallet_address")
  organizerVerifiedSnapshot  Boolean               @map("organizer_verified_snapshot")
  visibilityMode             VisibilityMode        @map("visibility_mode")
  paymentMode                PaymentMode           @map("payment_mode")
  ballotPolicy               BallotPolicy          @map("ballot_policy")
  startAt                    DateTime              @map("start_at")
  endAt                      DateTime              @map("end_at")
  resultRevealAt             DateTime              @map("result_reveal_at")
  minKarmaTier               Int                   @map("min_karma_tier")
  resetIntervalSeconds       Int                   @map("reset_interval_seconds")
  allowMultipleChoice        Boolean               @map("allow_multiple_choice")
  maxSelectionsPerSubmission Int                   @map("max_selections_per_submission")
  timezoneWindowOffset       Int                   @map("timezone_window_offset")
  paymentToken               String?               @map("payment_token")
  costPerBallot              String                @map("cost_per_ballot")
  onchainState               OnchainElectionState  @map("onchain_state")
  isStateSyncing             Boolean               @default(false) @map("is_state_syncing")
  lastStateSyncRequestedAt   DateTime?             @map("last_state_sync_requested_at")
  lastStateSyncTxHash        String?               @map("last_state_sync_tx_hash")
  createdAt                  DateTime              @default(now()) @map("created_at")
  updatedAt                  DateTime              @updatedAt @map("updated_at")
  draft                      ElectionDraft?        @relation(fields: [draftId], references: [id])
  openVoteSubmissions        OpenVoteSubmission[]
  voteSubmissions            VoteSubmission[]
  liveTally                  LiveTally[]
  finalizedTally             FinalizedTally[]
  resultSummary              ResultSummary?
  invalidOnchainElection     InvalidOnchainElection?

  @@index([draftId])
  @@map("onchain_elections")
}

model OpenVoteSubmission {
  id                BigInt          @id @default(autoincrement())
  electionRefId BigInt          @map("election_ref_id")
  onchainTxHash     String          @unique @map("onchain_tx_hash")
  voterAddress      String          @map("voter_address")
  blockNumber       Int             @map("block_number")
  blockTimestamp    DateTime        @map("block_timestamp")
  candidateKeys     Json            @map("candidate_keys")
  selectionCount    Int             @map("selection_count")
  ballotsSpent      Int             @map("ballots_spent")
  paymentAmount     String          @map("payment_amount")
  createdAt         DateTime        @default(now()) @map("created_at")
  onchainElection   OnchainElection @relation(fields: [electionRefId], references: [id])

  @@index([electionRefId, blockNumber])
  @@index([voterAddress])
  @@map("open_vote_submissions")
}

model InvalidOnchainElection {
  id                BigInt          @id @default(autoincrement())
  electionRefId BigInt          @unique @map("election_ref_id")
  reasonCode        String          @map("reason_code")
  reasonDetail      String?         @map("reason_detail")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  onchainElection   OnchainElection @relation(fields: [electionRefId], references: [id])

  @@index([reasonCode])
  @@map("invalid_onchain_elections")
}

model ElectionKey {
  id                       BigInt    @id @default(autoincrement())
  draftId                  BigInt?   @unique @map("draft_id")
  publicKey                String    @map("public_key")
  privateKeyCommitmentHash String    @unique @map("private_key_commitment_hash")
  privateKeyEncrypted      String    @map("private_key_encrypted")
  isRevealed               Boolean   @default(false) @map("is_revealed")
  revealedAt               DateTime? @map("revealed_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  draft                    ElectionDraft? @relation(fields: [draftId], references: [id])

  @@map("election_keys")
}

model ElectionCandidate {
  id           BigInt   @id @default(autoincrement())
  draftId      BigInt   @map("draft_id")
  candidateKey String   @map("candidate_key")
  imageUrl     String?  @map("image_url")
  displayOrder Int      @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  draft        ElectionDraft @relation(fields: [draftId], references: [id])

  @@unique([draftId, candidateKey])
  @@index([draftId, displayOrder])
  @@map("election_candidates")
}

model VoteSubmission {
  id              BigInt           @id @default(autoincrement())
  electionRefId BigInt         @map("election_ref_id")
  onchainTxHash   String           @unique @map("onchain_tx_hash")
  voterAddress    String           @map("voter_address")
  blockNumber     Int              @map("block_number")
  blockTimestamp  DateTime         @map("block_timestamp")
  encryptedBallot String           @map("encrypted_ballot")
  createdAt       DateTime         @default(now()) @map("created_at")
  onchainElection OnchainElection  @relation(fields: [electionRefId], references: [id])
  decryptedBallot DecryptedBallot?
  invalidBallots  InvalidBallot[]

  @@index([electionRefId, blockNumber])
  @@index([voterAddress])
  @@map("vote_submissions")
}

model DecryptedBallot {
  id               BigInt         @id @default(autoincrement())
  voteSubmissionId BigInt         @unique @map("vote_submission_id")
  candidateKeys    Json           @map("candidate_keys")
  nonce            String
  isValid          Boolean        @map("is_valid")
  validatedAt      DateTime?      @map("validated_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  voteSubmission   VoteSubmission @relation(fields: [voteSubmissionId], references: [id])

  @@index([isValid])
  @@map("decrypted_ballots")
}

model InvalidBallot {
  id               BigInt         @id @default(autoincrement())
  voteSubmissionId BigInt         @map("vote_submission_id")
  reasonCode       String         @map("reason_code")
  reasonDetail     String?        @map("reason_detail")
  createdAt        DateTime       @default(now()) @map("created_at")
  voteSubmission   VoteSubmission @relation(fields: [voteSubmissionId], references: [id])

  @@index([voteSubmissionId])
  @@index([reasonCode])
  @@map("invalid_ballots")
}

model LiveTally {
  id           BigInt   @id @default(autoincrement())
  electionRefId BigInt   @map("election_ref_id")
  candidateKey String   @map("candidate_key")
  count        Int
  updatedAt    DateTime @updatedAt @map("updated_at")
  onchainElection OnchainElection @relation(fields: [electionRefId], references: [id])

  @@unique([electionRefId, candidateKey])
  @@map("live_tally")
}

model FinalizedTally {
  id           BigInt   @id @default(autoincrement())
  electionRefId BigInt   @map("election_ref_id")
  candidateKey String   @map("candidate_key")
  count        Int
  voteRatio    Float    @map("vote_ratio")
  finalizedAt  DateTime @map("finalized_at")
  onchainElection OnchainElection @relation(fields: [electionRefId], references: [id])

  @@unique([electionRefId, candidateKey])
  @@map("finalized_tally")
}

model ResultSummary {
  id                    BigInt   @id @default(autoincrement())
  electionRefId     BigInt   @unique @map("election_ref_id")
  totalSubmissions      Int      @map("total_submissions")
  totalDecryptedBallots Int      @map("total_decrypted_ballots")
  totalValidVotes       Int      @map("total_valid_votes")
  totalInvalidVotes     Int      @map("total_invalid_votes")
  createdAt             DateTime @default(now()) @map("created_at")
  onchainElection       OnchainElection @relation(fields: [electionRefId], references: [id])

  @@map("result_summaries")
}

model IndexerCursor {
  key          String   @id
  blockNumber  String   @map("block_number")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("indexer_cursors")
}
